// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")

  projects     Project[]

  @@map("users")
}

model Project {
  id        String   @id @default(uuid())
  name      String
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  links     Link[]

  @@map("projects")
}

model Link {
  id        String   @id @default(uuid())
  name      String
  baseUrl   String   @map("base_url")
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  redirect        Redirect?
  linkParameters  LinkParameter[]

  @@map("links")
}

model Parameter {
  id        String   @id @default(uuid())
  key       String
  value     String
  createdAt DateTime @default(now()) @map("created_at")

  linkParameters LinkParameter[]

  @@map("parameters")
}

model LinkParameter {
  id          String @id @default(uuid())
  linkId      String @map("link_id")
  parameterId String @map("parameter_id")

  link      Link      @relation(fields: [linkId], references: [id], onDelete: Cascade)
  parameter Parameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@unique([linkId, parameterId])
  @@map("link_parameters")
}

model Redirect {
  id             String   @id @default(uuid())
  linkId         String   @unique @map("link_id")
  destinationUrl String   @map("destination_url")
  createdAt      DateTime @default(now()) @map("created_at")

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("redirects")
}